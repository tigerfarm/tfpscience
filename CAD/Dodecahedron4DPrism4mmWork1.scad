// --- PRISMATIC ROD MODULE ---
// Based on 4CubePrism3mm.scad logic
module rod(p1, p2, r) {
    v = p2 - p1;
    h = norm(v);
    if (h > 0.001) {
        translate(p1)
        // Handle rotation for alignment
        rotate(acos(v.z / h), cross([0, 0, 1], v))
        cylinder(h = h, r = r, center = false, $fn = rod_sides);
    }
}

// --- RENDER ---
union() {
    // Render Edges
    for (e = edges) {
        p1 = projectCoxeter(verts[e[0]]);
        p2 = projectCoxeter(verts[e[1]]);
        rod(p1, p2, diameter/2);
    }
    
    // Render Vertex Joints
    for (v = verts) {
        translate(projectCoxeter(v)) 
        sphere(d = vertex_diameter, $fn = 12);
    }
}