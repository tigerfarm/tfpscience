// --- COXETER PROJECTION (4D -> 3D) ---
// Projects the 4D vertices into 3D space based on the Coxeter plane
function projectCoxeter(p) =
    let(
        b1 = [1, 1, 1, 1] / 2,
        b2 = [1, 1, -1, -1] / 2,
        b3 = [1, -1, 1, -1] / 2
    )
    [
        p[0]*b1[0] + p[1]*b1[1] + p[2]*b1[2] + p[3]*b1[3],
        p[0]*b2[0] + p[1]*b2[1] + p[2]*b2[2] + p[3]*b2[3],
        p[0]*b3[0] + p[1]*b3[1] + p[2]*b3[2] + p[3]*b3[3]
    ] * size;

