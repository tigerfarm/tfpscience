// --- MODULES ---

// Coxeter projection from 4D → 3D
function projectCoxeter(p) =
    let(
        b1 = [1, 1, 1, 1] / 2,
        b2 = [1, 1, -1, -1] / 2,
        b3 = [1, -1, 1, -1] / 2
    )
    [
        p[0]*b1[0] + p[1]*b1[1] + p[2]*b1[2] + p[3]*b1[3],
        p[0]*b2[0] + p[1]*b2[1] + p[2]*b2[2] + p[3]*b2[3],
        p[0]*b3[0] + p[1]*b3[1] + p[2]*b3[2] + p[3]*b3[3]
    ] * edge_length;

// Helper: draw a prismatic rod between two 3D points
module rod(p1, p2) {
    v = p2 - p1;
    h = norm(v);
    if (h > 0) {
        translate(p1)
            rotate(acos(v.z/h), cross([0,0,1], v))
                cylinder(h, d=diameter, $fn=rod_sides);
    }
}

// --- MAIN RENDER ---

union() {
    // Render the Edges
    for (e = edges) {
        rod(projectCoxeter(verts[e[0]]), projectCoxeter(verts[e[1]]));
    }

    // Render the Vertices
    for (v = verts) {
        translate(projectCoxeter(v))
            sphere(d=vertex_size, $fn=16);
    }
}